    "vault relocation",
    "high-mass logistics",
    "substrate loading",
    "rigging constraints",
    "dynamic load factors"
  ],
  "measurementTechnique": [
    "substrate load validation",
    "rigging angle monitoring",
    "dynamic load factor modeling"
  ],
  "variableMeasured": [
    "vaultWeightLBS",
    "maxPointLoadLBS",
    "maxDistributedLoadPSF",
    "riggingAngleRange",
    "movementVelocityFTS",
    "substrateDeflectionIN"
  ],
  "spatialCoverage": {
    "@type": "Place",
    "name": "Winchester VA to Martinsburg WV corridor"
  },
  "temporalCoverage": "2025-09",
  "distribution": [
