      "value": 0.2,
      "unitCode": "MMT"
    },
    {
      "@type": "PropertyValue",
      "name": "floorDeflectionLimit",
      "description": "Maximum allowable floor deflection for supporting medical calibration equipment.",
      "value": "L/480"
    },
