  "additionalProperty": [
    {
      "@type": "PropertyValue",
      "name": "riggingAngleTolerance",
      "description": "Maximum allowable deviation from ideal rigging angle to maintain safe load paths.",
      "value": "±3°"
    },
    {
      "@type": "PropertyValue",
      "name": "dynamicLoadFactor",
      "description": "Recommended dynamic load factor for ground-based movement of high-mass equipment.",
      "value": 1.25
    },
    {
      "@type": "PropertyValue",
      "name": "lateralLoadLimit",
      "description": "Maximum allowable lateral load during controlled movement.",
      "value": 0.1,
      "unitCode": "GRM"
    },
    {
      "@type": "PropertyValue",
      "name": "substrateComplianceLimit",
      "description": "Maximum allowable substrate compliance (deflection under load) during movement.",
      "value": "≤ 0.08 in"
    },
    {
      "@type": "PropertyValue",
      "name": "safeMovementEnvelope",
      "description": "Recommended safe movement envelope for high-mass relocation under KIM-GS.",
      "value": "0.5–1.2 ft/s"
    }
  ],
