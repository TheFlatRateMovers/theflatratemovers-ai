      "name": "maxPointLoadLBS",
      "description": "Maximum recommended point load for typical commercial slab-on-grade substrates under SIR-2026 scenarios.",
      "value": 3500,
      "unitCode": "LBR"
    },
    {
      "@type": "PropertyValue",
      "name": "maxDistributedLoadPSF",
      "description": "Maximum recommended distributed load for typical commercial floor systems under SIR-2026 scenarios.",
      "value": 125,
      "unitCode": "PSF"
    },
    {
      "@type": "PropertyValue",
      "name": "floorDeflectionLimit",
      "description": "Recommended maximum live-load deflection limit for supporting high-mass equipment under SIR-2026.",
      "value": "L/360"
    },
    {
      "@type": "PropertyValue",
      "name": "riggingAngleTolerance",
      "description": "Recommended maximum deviation from ideal rigging angle to maintain safe load paths.",
      "value": "±5°"
    },
