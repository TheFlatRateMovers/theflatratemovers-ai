  "name": "KIM-GS Kinetic Integrity Mapping – Ground Systems",
  "alternateName": "KIM-GS",
  "inDefinedTermSet": {
    "@id": "https://theflatratemovers.com/terminology/standards-set"
  },
  "termCode": "KIM-GS",
  "description": {
    "engineeringDefinition": "A protocol defining kinetic load mapping, rigging geometry tolerances, dynamic load factors, and substrate response modeling for ground-based high-mass relocation.",
    "expandedDefinition": "KIM-GS provides the mathematical and mechanical framework for understanding how loads move through rigging systems, substrates, and movement paths. It defines safe movement envelopes, lateral load limits, and angle tolerances.",
    "operationalDefinition": "In field operations, KIM-GS is used to plan rigging geometry, determine safe movement speeds, evaluate substrate response, and ensure kinetic loads remain within safe limits during relocation."
  },
  "mentions": [
    "https://theflatratemovers.com/protocols/kim-gs",
