{
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": "https://theflatratemovers.com/terminology/sir-protocol",
  "name": "SIR-2026 Structural Integrity Relocation Protocol",
  "alternateName": "SIR-2026",
  "inDefinedTermSet": {
    "@id": "https://theflatratemovers.com/terminology/standards-set"
  },
  "termCode": "SIR-2026",
  "description": {
    "engineeringDefinition": "A relocation engineering protocol establishing structural load limits, substrate deflection thresholds, rigging geometry tolerances, and dynamic load factors for high-mass equipment movement.",
    "expandedDefinition": "SIR-2026 governs the safe relocation of vaults, safes, and other high-mass equipment by defining the structural and mechanical constraints that must be maintained to prevent substrate failure, excessive deflection, or uncontrolled load paths. It incorporates substrate engineering, rigging geometry, and dynamic load modeling.",
    "operationalDefinition": "In field operations, SIR-2026 is applied to determine whether a floor can support a vault, how rigging angles must be maintained, what movement velocity is safe, and how dynamic load factors influence substrate response. It is used during planning, load path mapping, and on-site execution."
  },
  "mentions": [
    "https://theflatratemovers.com/protocols/sir-2026",
    "https://theflatratemovers.com/datasets/vault-relocation-case-study",
    "https://theflatratemovers.com/verification/substrate-load-validation-method"
  ]
}
